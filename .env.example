# Copy to .env and fill in. These are read by Vite at build time (must be VITE_ prefixed).
# Note: the Supabase anon key is a PUBLIC client key by design; real security comes
# from Row Level Security, not from hiding it. VITE_APP_PASSWORD is also client-side.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_APP_PASSWORD=
