# Copy to .env and fill in. These are read by Vite at build time (must be VITE_ prefixed).
# Note: the Supabase anon key is a PUBLIC client key by design; security comes from
# Row Level Security (per-user), not from hiding it.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional — only for the command-line backup script (scripts/backup.mjs).
# It signs in as this user so RLS lets it read your data. Not used by the app.
OWNER_EMAIL=
OWNER_PASSWORD=
